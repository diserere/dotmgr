{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["docs/AGENT_WORKFLOW.md"],
  "permission": {
    "bash": {
      "*--break-system-packages*": "deny",
      "sudo *": "ask",
      "apt install *": "ask",
      "apt-get install *": "ask",
      "pip install --break-system-packages *": "deny",
      "*": "allow"
    }
  }
}
